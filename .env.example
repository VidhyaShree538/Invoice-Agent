# Extraction provider: tesseract (default) or llm
EXTRACTION_PROVIDER=tesseract

# Optional local LLM model to use when EXTRACTION_PROVIDER=llm
# Requires Ollama installed locally, e.g. `ollama pull llama3:latest`
OLLAMA_MODEL=llama3:latest

# Optional path to the Tesseract executable, if it is not on PATH
# E.g., TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=

# System path to Poppler binaries (optional, useful on Windows)
# E.g., POPPLER_PATH=C:\Program Files\poppler-23.08.0\Library\bin
POPPLER_PATH=
